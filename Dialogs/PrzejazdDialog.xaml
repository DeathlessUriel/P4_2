<Window x:Class="TransportApp.Dialogs.PrzejazdDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Przejazd"
        Height="700"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">

        <ScrollViewer>

            <StackPanel>

                <TextBlock Text="Data rozpoczęcia"/>
                <DatePicker SelectedDate="{Binding DataRozpoczecia}"
                            Margin="0 0 0 10"/>

                <TextBlock Text="Data zakończenia"/>
                <DatePicker SelectedDate="{Binding DataZakonczenia}"
                            Margin="0 0 0 10"/>

                <TextBlock Text="Adres startu"/>

                <ComboBox ItemsSource="{Binding Adresy}"
                          SelectedItem="{Binding SelectedAdresStart}"
                          DisplayMemberPath="Miasto"
                          Margin="0 0 0 10"/>

                <TextBlock Text="Adres docelowy"/>

                <ComboBox ItemsSource="{Binding Adresy}"
                          SelectedItem="{Binding SelectedAdresStop}"
                          DisplayMemberPath="Miasto"
                          Margin="0 0 0 10"/>

                <TextBlock Text="Kierowca"/>

                <ComboBox ItemsSource="{Binding Kierowcy}"
                          SelectedItem="{Binding SelectedKierowca}"
                          DisplayMemberPath="Nazwisko"
                          Margin="0 0 0 10"/>

                <TextBlock Text="Pojazd"/>

                <ComboBox ItemsSource="{Binding Pojazdy}"
                          SelectedItem="{Binding SelectedPojazd}"
                          DisplayMemberPath="NumerRejestracyjny"
                          Margin="0 0 0 10"/>

                <TextBlock Text="Stan licznika start"/>
                <TextBox Text="{Binding Przejazd.StanLicznikaStart}"
                         Margin="0 0 0 10"/>

                <TextBlock Text="Stan licznika stop"/>
                <TextBox Text="{Binding Przejazd.StanLicznikaStop}"
                         Margin="0 0 0 20"/>

                <Button Content="Zapisz"
                        Height="45"
                        Command="{Binding SaveCommand}"/>

            </StackPanel>

        </ScrollViewer>

    </Grid>
</Window>