<Application x:Class="TransportApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:TransportApp.ViewModels"
             xmlns:views="clr-namespace:TransportApp.Views">

    <Application.Resources>
        <ResourceDictionary>
           
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light"
                                             PrimaryColor="Blue"
                                             SecondaryColor="DeepPurple" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            
            <DataTemplate DataType="{x:Type vm:PojazdyViewModel}">
                <views:PojazdyView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:KierowcyViewModel}">
                <views:KierowcyView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ZleceniaViewModel}">
                <views:ZleceniaView/>
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>
