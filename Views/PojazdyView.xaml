<UserControl x:Class="TransportApp.Views.PojazdyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Pojazdy"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0 0 0 20"/>

        <Border Grid.Row="1"
                CornerRadius="10"
                BorderBrush="#DDD"
                BorderThickness="1">

            <DataGrid ItemsSource="{Binding Pojazdy}"
                      SelectedItem="{Binding SelectedPojazd}"
                      AutoGenerateColumns="False"
                      RowStyle="{StaticResource PojazdRowStyle}"
                      IsReadOnly="True">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Rejestracja"
                        Binding="{Binding NumerRejestracyjny}"/>

                    <DataGridTextColumn Header="Rok"
                        Binding="{Binding RokProdukcji}"/>

                    <DataGridTextColumn Header="Ładowność"
                        Binding="{Binding DopuszczalnaLadownosc}"/>

                    <DataGridTextColumn Header="LDM"
                        Binding="{Binding PojemnoscLdm}"/>

                    <DataGridTextColumn Header="Przegląd"
                        Binding="{Binding DataPrzegladu}"/>

                    <DataGridTextColumn Header="Ubezpieczenie"
                        Binding="{Binding DataUbezpieczenia}"/>

                    <DataGridTextColumn Header="Model ID"
                        Binding="{Binding IdModelu}"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 20 0 0">

            <Button Content="Dodaj"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Command="{Binding AddCommand}"/>

            <Button Content="Edytuj"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Command="{Binding EditCommand}"/>

            <Button Content="Usuń"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Command="{Binding DeleteCommand}"/>

            <Button Content="Dodaj zdjęcie"
            Command="{Binding AddPhotoCommand}"
            Width="120"
            Height="40"
            Margin="5"/>

            <Button Content="Pokaż zdjęcia"
            Command="{Binding ShowPhotosCommand}"
            Width="120"
            Height="40"
            Margin="5"/>
        </StackPanel>

    </Grid>
</UserControl>