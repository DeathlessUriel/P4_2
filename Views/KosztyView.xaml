<UserControl x:Class="TransportApp.Views.KosztyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Koszty"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0 0 0 20"/>

        <Border Grid.Row="1"
                BorderThickness="1"
                BorderBrush="#DDD"
                CornerRadius="10">

            <DataGrid ItemsSource="{Binding Koszty}"
                      SelectedItem="{Binding SelectedKoszt}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Rodzaj"
                                        Binding="{Binding RodzajKosztu}"/>

                    <DataGridTextColumn Header="Opis"
                                        Binding="{Binding OpisKosztu}"/>

                    <DataGridTextColumn Header="Wartość"
                                        Binding="{Binding WartoscKosztu}"/>

                    <DataGridTextColumn Header="Przejazd"
                                        Binding="{Binding IdPrzejazd}"/>

                    <DataGridTextColumn Header="Waluta"
                                        Binding="{Binding IdKursuNavigation.IdValutyNavigation.KodIso}"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 20 0 0">

            <Button Content="Dodaj"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Command="{Binding AddCommand}"/>

            <Button Content="Edytuj"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Command="{Binding EditCommand}"/>

            <Button Content="Usuń"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Command="{Binding DeleteCommand}"/>

        </StackPanel>

    </Grid>
</UserControl>