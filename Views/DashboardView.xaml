<UserControl x:Class="TransportApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="350"/>
            </Grid.RowDefinitions>


            <UniformGrid Columns="2" Grid.Row="0">

                <Border Background="#4CAF50"
                Margin="10"
                CornerRadius="15"
                Padding="20">

                <StackPanel>

                    <TextBlock Text="Pojazdy"
                           FontSize="20"
                           Foreground="White"/>

                    <TextBlock Text="{Binding LiczbaPojazdow}"
                           FontSize="40"
                           FontWeight="Bold"
                           Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#2196F3"
                Margin="10"
                CornerRadius="15"
                Padding="20">

                <StackPanel>

                    <TextBlock Text="Kierowcy"
                           FontSize="20"
                           Foreground="White"/>

                    <TextBlock Text="{Binding LiczbaKierowcow}"
                           FontSize="40"
                           FontWeight="Bold"
                           Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#FF9800"
                Margin="10"
                CornerRadius="15"
                Padding="20">

                <StackPanel>

                    <TextBlock Text="Zlecenia"
                           FontSize="20"
                           Foreground="White"/>

                    <TextBlock Text="{Binding LiczbaZlecen}"
                           FontSize="40"
                           FontWeight="Bold"
                           Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#E91E63"
                Margin="10"
                CornerRadius="15"
                Padding="20">

                <StackPanel>

                    <TextBlock Text="Koszty"
                           FontSize="20"
                           Foreground="White"/>

                    <TextBlock Text="{Binding SumaKosztow}"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#673AB7"
                Margin="10"
                CornerRadius="15"
                Padding="20">

                <StackPanel>

                    <TextBlock Text="Przychody"
                           FontSize="20"
                           Foreground="White"/>

                    <TextBlock Text="{Binding SumaPrzychodow}"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="White"/>

                </StackPanel>

            </Border>

        </UniformGrid>

        
        <Border Grid.Row="1"
            Margin="10"
            Padding="20"
            CornerRadius="15"
            Background="White">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    
                </Grid.RowDefinitions>

                <TextBlock Text="Przejazdy miesięczne"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,20"
                   Grid.Row="0"/>

                
                <oxy:PlotView Model="{Binding ChartModel}"
                      Grid.Row="1"/>
            </Grid>
        </Border>

    </Grid>
    </ScrollViewer>
</UserControl>