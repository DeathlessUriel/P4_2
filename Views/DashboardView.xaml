<UserControl x:Class="TransportApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="30">

        <UniformGrid Columns="2">

            <Border Background="#4CAF50"
                    Margin="10"
                    CornerRadius="15"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Pojazdy"
                               FontSize="20"
                               Foreground="White"/>

                    <TextBlock Text="{Binding LiczbaPojazdow}"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#2196F3"
                    Margin="10"
                    CornerRadius="15"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Kierowcy"
                               FontSize="20"
                               Foreground="White"/>

                    <TextBlock Text="{Binding LiczbaKierowcow}"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#FF9800"
                    Margin="10"
                    CornerRadius="15"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Zlecenia"
                               FontSize="20"
                               Foreground="White"/>

                    <TextBlock Text="{Binding LiczbaZlecen}"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#E91E63"
                    Margin="10"
                    CornerRadius="15"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Koszty"
                               FontSize="20"
                               Foreground="White"/>

                    <TextBlock Text="{Binding SumaKosztow}"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

            <Border Background="#673AB7"
                    Margin="10"
                    CornerRadius="15"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Przychody"
                               FontSize="20"
                               Foreground="White"/>

                    <TextBlock Text="{Binding SumaPrzychodow}"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"/>

                </StackPanel>

            </Border>

        </UniformGrid>

    </Grid>
</UserControl>