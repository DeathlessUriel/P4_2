<UserControl x:Class="TransportApp.Views.ZleceniaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid ItemsSource="{Binding Zlecenia}"
                  SelectedItem="{Binding SelectedZlecenie}"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Numer"
                                    Binding="{Binding NumerZlecenia}"/>

                <DataGridTextColumn Header="Data"
                                    Binding="{Binding DataPrzyjecia}"/>

                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0 10 0 0">

            <Button Content="Pokaż koszt"
                    Command="{Binding PokazKosztCommand}"
                    Width="150"
                    Margin="5"/>

            <TextBlock Text="{Binding KosztZlecenia}"
                       VerticalAlignment="Center"
                       FontSize="16"
                       Margin="10"/>
        </StackPanel>
    </Grid>
</UserControl>
