<UserControl x:Class="TransportApp.Views.PrzejazdyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Przejazdy"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0 0 0 20"/>

        <Border Grid.Row="1"
                BorderThickness="1"
                BorderBrush="#DDD"
                CornerRadius="10">

            <DataGrid ItemsSource="{Binding Przejazdy}"
                      SelectedItem="{Binding SelectedPrzejazd}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Start"
                                        Binding="{Binding DataRozpoczecia}"/>

                    <DataGridTextColumn Header="Koniec"
                                        Binding="{Binding DataZakonczenia}"/>

                    <DataGridTextColumn Header="Kierowca"
                                        Binding="{Binding IdKierowcaNavigation.Nazwisko}"/>

                    <DataGridTextColumn Header="Pojazd"
                                        Binding="{Binding IdPojazdNavigation.NumerRejestracyjny}"/>

                    <DataGridTextColumn Header="Licznik start"
                                        Binding="{Binding StanLicznikaStart}"/>

                    <DataGridTextColumn Header="Licznik stop"
                                        Binding="{Binding StanLicznikaStop}"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 20 0 0">
            <Button Content="Pokaż zysk"
                    Width="140"
                    Height="40"
                    Margin="5"
                     Command="{Binding PokazZyskCommand}"/>
            
            <Button Content="Dodaj"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Command="{Binding AddCommand}"/>

            <Button Content="Edytuj"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Command="{Binding EditCommand}"/>

            <Button Content="Usuń"
                    Width="120"
                    Height="40"
                    Margin="5"
                    Command="{Binding DeleteCommand}"/>

        </StackPanel>

    </Grid>
</UserControl>